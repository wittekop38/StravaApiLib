<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

	<PropertyGroup>
		<PackageId>StravaApiLib</PackageId>
		<Version>1.1.0</Version>
		<Authors>wittekop</Authors>
		<Description>A lightweight .NET client library for the Strava API v3.</Description>

		<RepositoryUrl>https://github.com/wittekop38/StravaApiLib</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageProjectUrl>https://github.com/wittekop38/StravaApiLib</PackageProjectUrl>
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="StravaApiLib.Tests\**" />
	  <EmbeddedResource Remove="StravaApiLib.Tests\**" />
	  <None Remove="StravaApiLib.Tests\**" />
	</ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="10.0.7" />
  </ItemGroup>

</Project>
